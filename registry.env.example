# 复制为 registry.env，填写你要推送/拉取的镜像全名
# 推送前在本机执行: docker login <仓库地址>

# Docker Hub（公开仓库示例）
# DOCKER_IMAGE=你的用户名/gemini-h5:latest

# 阿里云 ACR 个人版（杭州示例，以控制台公网地址为准）
# DOCKER_IMAGE=crpi-v6rtj1tjk3pa7z2d.cn-hangzhou.personal.cr.aliyuncs.com/tangcong0526/gemini-h5:latest

# Gitee 容器镜像
# DOCKER_IMAGE=registry.gitee.com/你的用户名/gemini-h5:latest

DOCKER_IMAGE=你的仓库地址/命名空间/gemini-h5:latest
